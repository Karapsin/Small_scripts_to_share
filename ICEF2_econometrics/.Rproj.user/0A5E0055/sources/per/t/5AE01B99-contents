# Problem 4

a) 

The earliest mention about that deal is 2008/02/01: https://www.theguardian.com/media/pda/2008/jun/03/yahoomicrosoftatimeline 

Prices for YHOO are taken from this link: https://www.investing.com/equities/yahoo-inc-historical-data 

So the event window is: 2008/01/29 - 2008/02/04
Estimation window: 2007/05/20 - 2008/01/28

But 02.02 and 03.02 are weekends, that is why I extend event window: 
event window is: 2008/01/29 - 2008/02/06

Below is the code for data upload and convenient event study analysis.

```{r c7}
library(tidyr)
df <- 
tq_get(c("MSFT", "^GSPC"), 
       from="2007-05-23", 
       to="2008-02-07"
  )%>%
  select(date, symbol, close)%>%
  rbind(read.csv("AABA.csv")%>%
          rename(date=1, close=2)%>%
          mutate(symbol='YHOO')%>%
          select(date, symbol, close)%>%
          mutate(date = as.Date(date, format="%m/%d/%Y"))%>%
          filter(date>=as.Date("2007-05-23"))
  )%>%
  group_by(symbol)%>%
  arrange(date)%>%
  mutate(log_return = log(close) - log(lag(close, 1)))%>%
  select(-close)%>%
  filter(!is.na(log_return))%>%
  pivot_wider(names_from = "symbol", values_from = "log_return")

df_estimation <- df%>%filter(date<as.Date("2008/01/29"))
df_event <- df%>%filter(date>=as.Date("2008/01/29"))

MSFT_returns_event <- df_event$MSFT
YHOO_returns_event <- df_event$YHOO
Market_returns_event <- df_event$`^GSPC`

MSFT_returns_est <- df_estimation$MSFT
YHOO_returns_est <- df_estimation$YHOO
Market_returns_est <- df_estimation$`^GSPC`

event_study <- function(share_return_event,
                        share_return_est,
                        market_returns_event,
                        market_returns_est
               ){
  
  model <- lm(share_return_est~market_returns_est)
  model_coeff <- as.numeric(model$coefficients)
  
  if(model_coeff[2]%>%is.na()){
    model_coeff[2] <- 0
  }
  
  print("Market model:")
  print(summary(model))
  
  event_window <- length(share_return_event)
  estimation_window <- length(share_return_est)
  
  out_of_sample <- as.matrix(cbind(rep(1, event_window), market_returns_event)) 
  in_sample <- as.matrix(cbind(rep(1, estimation_window), market_returns_est))
  
  predictions <- out_of_sample %*% model_coeff
  abnorm_returns <- share_return_event - predictions
  
  ones <- diag(event_window)
  
  var_abnorm <- (summary(model)$sigma)^2*(ones + out_of_sample %*% solve(t(in_sample) %*% in_sample)%*% t(out_of_sample))

  c_matrix <- t(lower.tri(matrix(1, event_window, event_window), diag = TRUE))
  event_car <- c(rep(0, event_window)) # c vector from the lecture
  event_car[event_window/2] <- 1
  c_matrix <- cbind(c_matrix, event_car)
  CARs_for_each_c <- t(c_matrix) %*% abnorm_returns
  
  print("normal returns:")
  print(predictions)
  
  print("abnormal returns:")
  print(abnorm_returns)
  
  print("CARs:")
  print(CARs_for_each_c[-(event_window+1)])
  
  Var_for_each_c <- diag(t(c_matrix) %*% var_abnorm %*% c_matrix)
  SCAR_for_each_c <- CARs_for_each_c/sqrt(Var_for_each_c)
  
  print("SCARs:")
  print(SCAR_for_each_c[-(event_window+1)])
  
  print("p-values, z-test:")
  print((2*(1 - pnorm(abs(SCAR_for_each_c))))[-(event_window+1)])

  print("p-values, t-test:")
  print((2*(1 - pt(abs(SCAR_for_each_c), df = estimation_window - 2)))[-(event_window+1)])
}

```

b, c, d)

As we can see from the output below, market returns' impact on YHOO returns is significant, however $R^2$ is quite low, roughly 25%.

In the end we see that both tests provide p-values which are less than 0.0001 starting from the 4th day of the event window (event day), so we can reject the null about no impact.

```{r c8}
event_study(YHOO_returns_event, 
            YHOO_returns_est, 
            Market_returns_event, 
            Market_returns_est
)
```

e)
For the constant mean model I'm going to use t-test. In this case abnormal returns are the deviations of actual returns from the mean from estimation period, so we need to test if CARs are significantly different from 0. 
```{r c9}
library(purrr)
YHOO_mean <-  mean(YHOO_returns_est)
normal_returns <- rep(YHOO_mean, length(YHOO_returns_event))
abnormal_returns <- YHOO_returns_event-normal_returns
CARs <- cumsum(abnormal_returns)

print("normal returns:")
print(normal_returns)

print("abnormal returns:")
print(abnormal_returns)

print("CARs:")
print(CARs)

print("t-test:")
print(map_chr(2:length(abnormal_returns), 
              ~paste0(.x, " days p-value: ", t.test(abnormal_returns[1:.x])$p.value)
     )
)

```

As can be seen, we can not reject the null with such model, so we can not conclude that event had an impact on returns.


f) for MSFT conclusion is the same, however returns are negative in this case.
```{r c10}
event_study(MSFT_returns_event, 
            MSFT_returns_est, 
            Market_returns_event, 
            Market_returns_est
)
```
